FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

COPY requirements-openwebui.txt ./
RUN pip install --no-cache-dir -r requirements-openwebui.txt

COPY . .

EXPOSE 5002

CMD ["python3", "openwebui_server.py"]
